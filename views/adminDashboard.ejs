<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kainos Admin Dashboard</title>
    <!-- Bulma CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="has-background-light" style="min-height: 100vh;">

    <!-- Navigation Bar (Dark theme to match Kainos branding) -->
    <nav class="navbar is-dark has-shadow" role="navigation" aria-label="main navigation">
        <div class="container">
            <div class="navbar-brand">
                <a class="navbar-item" href="#">
                    <!-- Replaced logo image with text header -->
                    <span class="is-size-4 has-text-weight-black has-text-white tracking-wide">KAINOS</span>
                    <span class="has-text-weight-light is-size-5 ml-3 has-text-grey-light">| Admin Portal</span>
                </a>
            </div>

            <div class="navbar-end">
                <div class="navbar-item">
                    <div class="buttons">
                        <a href="/logout" class="button is-danger is-light">
                            <span class="icon is-small"><i class="fas fa-sign-out-alt"></i></span>
                            <span>Logout</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content Container -->
    <section class="section">
        <div class="container">
            
            <!-- Dashboard Header Section -->
            <div class="level mb-6">
                <div class="level-left">
                    <div class="level-item">
                        <div>
                            <h1 class="title is-2 has-text-dark">Admin Dashboard</h1>
                            <p class="subtitle is-6 has-text-grey">Manage your organization's users and employees.</p>
                        </div>
                    </div>
                </div>
            </div>

          
            <div class="block mb-6">
                <div class="buttons">
                    <a href="/employees/add" class="button is-link is-medium is-responsive">
                        <span class="icon"><i class="fas fa-user-plus"></i></span>
                        <span>Add New Employee</span>
                    </a>
                    <a href="/users/add" class="button is-primary is-medium is-responsive">
                        <span class="icon"><i class="fas fa-graduation-cap"></i></span>
                        <span>Add New User</span>
                    </a>
                </div>
            </div>

          
            <div class="columns is-desktop">
                
              
                <div class="column">
                    <div class="box p-5" style="height: 100%; display: flex; flex-direction: column; justify-content: space-between; border-top: 4px solid #1c75bc;">
                        <div class="mb-5">
                            <div class="level is-mobile mb-4">
                                <div class="level-left">
                                    <h2 class="title is-4 mb-0 Treat-text-dark">Employees</h2>
                                </div>
                                <div class="level-right">
                                    <span class="icon is-medium has-text-link"><i class="fas fa-id-badge fa-lg"></i></span>
                                </div>
                            </div>
                        </div>
                        <div>
                       
                            <a href="/employees/" class="button is-link is-fullwidth">
                                <span>View All Employees</span>
                                <span class="icon is-small"><i class="fas fa-arrow-right"></i></span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Users Card -->
                <div class="column">
                    <div class="box p-5" style="height: 100%; display: flex; flex-direction: column; justify-content: space-between; border-top: 4px solid #00b2a9;">
                        <div class="mb-5">
                            <div class="level is-mobile mb-4">
                                <div class="level-left">
                                    <h2 class="title is-4 mb-0 has-text-dark">Users</h2>
                                </div>
                                <div class="level-right">
                                    <span class="icon is-medium has-text-primary"><i class="fas fa-laptop-code fa-lg"></i></span>
                                </div>
                            </div>
                        </div>
                        <div>
                     
                            <a href="/users/" class="button is-primary is-fullwidth">
                                <span>View All Users</span>
                                <span class="icon is-small"><i class="fas fa-arrow-right"></i></span>
                            </a>
                        </div>
                    </div>
                </div>

            </div> 

        </div>
    </section>

</body>

</html>