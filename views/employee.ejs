<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Information</title>

    <!-- Bulma + Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="has-background-light">

<section class="section">
  <div class="container">

    <div class="columns is-centered">
      <div class="column is-two-thirds">

        <!-- Card -->
        <div class="card">
          <div class="card-content">

            <h1 class="title has-text-centered">
              <span class="icon">
                <i class="fas fa-user"></i>
              </span>
              Employee Information
            </h1>

            <% if (employee) { %>

              <!-- Table -->
              <div class="table-container">
                <table class="table is-striped is-hoverable is-fullwidth">
                  <thead>
                    <tr>
                      <th><span class="icon"><i class="fas fa-user"></i></span> Name</th>
                      <th><span class="icon"><i class="fas fa-envelope"></i></span> Address</th>
                      <th><span class="icon"><i class="fas fa-briefcase"></i></span> Salary</th>
                       <th><span class="icon"><i class="fas fa-briefcase"></i></span> Role</th>
                        <th><span class="icon"><i class="fas fa-briefcase"></i></span> Employee Number</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td><%= employee.name %></td>
                      <td><%= employee.address %></td>
                      <td><%= employee.salary %></td>
                      <td><%= employee.role %></td>
                      <td><%= employee.employeeNumber %></td>
                    </tr>
                  </tbody>
                </table>
              </div>

            <% } else { %>

              <!-- Empty State -->
              <div class="notification is-warning has-text-centered">
                <span class="icon">
                  <i class="fas fa-exclamation-triangle"></i>
                </span>
                No employee found.
              </div>

            <% } %>

            <!-- Back Button -->
            <div class="has-text-centered mt-5">
              <a href="/employee/add" class="button is-link is-light">
                <span class="icon">
                  <i class="fas fa-arrow-left"></i>
                </span>
            
                <span>Add Another Employee</span>
              </a>
            </div>

          </div>
        </div>

      </div>
    </div>

  </div>
</section>

</body>
</html>
