<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New User</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="has-background-light">

    <section class="section">
        <div class="container">

            <div class="columns is-centered">
                <div class="column is-half">

                    <!-- Card -->
                    <div class="card">
                        <div class="card-content">

                            <h1 class="title has-text-centered">
                                <span class="icon">
                                    <i class="fas fa-user-plus"></i>
                                </span>
                                Add New Employee
                            </h1>

                            <!-- The hidden-by-default error notification -->
                            <div id="error-notification" class="notification is-danger is-light is-hidden">
                                <button class="delete" onclick="this.parentElement.remove()"></button>
                                🛑 <strong>Error:</strong> All fields are required. Please fill out the entire form
                                before saving.
                            </div>
                            <form action="/employees/add" method="post">

                                <!-- Name -->
                                <div class="field">
                                    <label class="label">Name</label>
                                    <div class="control has-icons-left">
                                        <input class="input" type="text" name="name" placeholder="Enter name" required>
                                        <span class="icon is-small is-left">
                                            <i class="fas fa-user"></i>
                                        </span>
                                    </div>
                                </div>

                                <!-- Address -->
                                <div class="field">
                                    <label class="label">Address</label>
                                    <div class="control has-icons-left">
                                        <input class="input" type="text" name="address" placeholder="Enter address">
                                        <span class="icon is-small is-left">
                                            <i class="fas fa-home"></i>
                                        </span>
                                    </div>
                                </div>
                                <!-- Salary -->
                                <div class="field">
                                    <label class="label">Salary</label>
                                    <div class="control has-icons-left">
                                        <input class="input" type="number" name="salary" placeholder="Enter salary">
                                        <span class="icon is-small is-left">
                                            <i class="fas fa-pound-sign"></i>
                                        </span>
                                    </div>
                                </div>
                                <!-- Role -->
                                <div class="field">
                                    <label class="label">Role</label>
                                    <div class="control has-icons-left">
                                        <input class="input" type="text" name="role" placeholder="Enter role">
                                        <span class="icon is-small is-left">
                                            <i class="fas fa-briefcase"></i>
                                        </span>
                                    </div>
                                </div>
                                <!-- Submit -->
                                <div class="field mt-5">
                                    <div class="control">
                                        <button class="button is-success is-fullwidth">
                                            <span class="icon">
                                                <i class="fas fa-check"></i>
                                            </span>
                                            <span>Submit</span>
                                        </button>
                                    </div>
                                </div>

                            </form>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

</body>
<script>
    document.addEventListener('DOMContentLoaded', () => {
    // 1. Check the URL for the ?error=required parameter
    const urlParams = new URLSearchParams(window.location.search);
   
    if (urlParams.get('error') === 'required') {
        const errorNotification = document.getElementById('error-notification');
        if (errorNotification) {
            // 2. Reveal the Bulma alert by removing the hidden class
            errorNotification.classList.remove('is-hidden');
        }
    }
});
</script>

</html>